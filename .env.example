# Hospital Database Backup — Required Environment Variables
# Copy to .env and fill in real values:
#   cp .env.example .env
#   chmod 600 .env
#   nano .env
#
# All passwords: minimum 16 characters, mix of upper/lower/numbers/symbols.
# Each service MUST have a UNIQUE password — no reuse.

# ─── Environment ───
APP_ENV=development          # development | staging | production
# PRODUCTION_CONFIRMED=yes   # Required to run on production

# ─── Environment-Specific Alerts ───
# DEV_ADMIN_EMAIL=
# DEV_TELEGRAM_CHAT_ID=
# STAGING_ADMIN_EMAIL=
# STAGING_TELEGRAM_CHAT_ID=

# ─── SQL Server ───
SQL_USER=hospital_dba_admin
SQL_PASSWORD=
DBA_ADMIN_PASSWORD=
MASTER_KEY_PASSWORD=
CERT_BACKUP_PASSWORD=

# ─── Application Logins (RBAC) ───
APP_RW_PASSWORD=
APP_RO_PASSWORD=
APP_BILLING_PASSWORD=
APP_AUDIT_PASSWORD=

# ─── Email / SMTP ───
SMTP_PASSWORD=

# ─── Certificate S3 Upload ───
CERT_S3_ENCRYPTION_KEY=

# ─── Audit Log Export ───
AUDIT_EXPORT_PASSWORD=

# ─── Telegram Alerts ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Grafana ───
GRAFANA_ADMIN_PASSWORD=
GRAFANA_SECRET_KEY=

# ─── TLS / Network Security ───
# SQL_REQUIRE_TLS=true         # Force encrypted connections (-N flag)
# SQL_TRUST_CERT=true          # Trust self-signed cert (-C). Set false for CA-signed.

# ─── AWS (only if not using IAM roles/profiles) ───
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
