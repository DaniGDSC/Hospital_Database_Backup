# Hospital Database Backup — Required Environment Variables
# Copy to .env and fill in real values:
#   cp .env.example .env
#   chmod 600 .env
#   nano .env
#
# All passwords: minimum 16 characters, mix of upper/lower/numbers/symbols.
# Each service MUST have a UNIQUE password — no reuse.

# ─── SQL Server ───
SQL_PASSWORD=
MASTER_KEY_PASSWORD=
CERT_BACKUP_PASSWORD=

# ─── Application Logins (RBAC) ───
APP_RW_PASSWORD=
APP_RO_PASSWORD=
APP_BILLING_PASSWORD=
APP_AUDIT_PASSWORD=

# ─── Email / SMTP ───
SMTP_PASSWORD=

# ─── Certificate S3 Upload ───
CERT_S3_ENCRYPTION_KEY=

# ─── Audit Log Export ───
AUDIT_EXPORT_PASSWORD=

# ─── Telegram Alerts ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Grafana ───
GRAFANA_ADMIN_PASSWORD=
GRAFANA_SECRET_KEY=

# ─── AWS (only if not using IAM roles/profiles) ───
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
